# Copy to .env and adjust. XAMPP MySQL defaults: user root, empty password.
DATABASE_URL="mysql://root:@127.0.0.1:3306/jewellery_erp_next"

# Server
PORT=4000
# Comma-separated allowed origins for CORS (the Next.js frontend)
CORS_ORIGIN="http://localhost:3000"

# JWT
JWT_SECRET="change-this-to-a-long-random-string"
JWT_EXPIRES_IN="7d"

# File uploads (relative to backend root)
UPLOAD_DIR="uploads"
MAX_UPLOAD_MB=5
